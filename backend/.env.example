# ══════════════════════════════════════════════════════════
# HireIQ — Environment Variables
# ══════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env — it is in .gitignore

# GitHub Personal Access Token
# Increases API rate limit from 60 → 5000 requests/hour
# Create one at: https://github.com/settings/tokens
# Required scopes: public_repo (read-only is fine)
GITHUB_TOKEN=your_github_personal_access_token_here

# Codeforces API credentials (optional)
CODEFORCES_KEY=optional
CODEFORCES_SECRET=optional

# Database URL (default: local SQLite, no setup needed)
DATABASE_URL=sqlite+aiosqlite:///./hireiq.db

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Server configuration
HOST=0.0.0.0
PORT=8000
DEBUG=true
