# ══════════════════════════════════════════════════════════
# HireIQ — Environment Variables
# ══════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# GitHub Personal Access Token (increases API rate limit from 60 to 5000/hr)
GITHUB_TOKEN=your_github_personal_access_token

# Codeforces API credentials (optional, for higher rate limits)
CODEFORCES_KEY=optional
CODEFORCES_SECRET=optional

# Database URL (default: local SQLite)
DATABASE_URL=sqlite+aiosqlite:///./hireiq.db

# CORS origins (comma-separated, for production use specific origins)
CORS_ORIGINS=http://localhost:5173

# Server configuration
HOST=0.0.0.0
PORT=8000
DEBUG=true
